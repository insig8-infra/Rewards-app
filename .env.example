# Backend
NODE_ENV=development
PORT=3000
# Local default is 127.0.0.1 when HOST is unset. Use HOST=0.0.0.0 for container deployments.
HOST=127.0.0.1
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/volt_rewards
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/volt_rewards
# Test/staging deployment runtime should use the Neon pooled connection string.
NEON_CONNECTION_STRING=
# Prisma CLI/migration operations should use the Neon direct connection string.
NEON_DIRECT_URL=
JWT_SECRET=replace-with-local-dev-secret
QR_TOKEN_SECRET=replace-with-local-dev-secret
CORS_ORIGIN=http://127.0.0.1:3001,http://localhost:3001,http://127.0.0.1:3002,http://localhost:3002,http://127.0.0.1:3003,http://localhost:3003,http://127.0.0.1:8081,http://localhost:8081

# BUSY PUSH connector receiver. Use separate values per local/test/staging/production environment.
BUSY_INTEGRATION_CLIENT_ID=volt-busy-test
BUSY_INTEGRATION_API_KEY=replace-with-generated-busy-test-api-key

# Public API base used when generating stable media URLs for private object storage.
# Include the /api prefix. Railway example: https://volt-rewardsapi-production.up.railway.app/api
API_PUBLIC_BASE_URL=http://127.0.0.1:3000/api

# Media storage:
# - Use local in development to avoid remote object-storage traffic while we iterate.
# - Use railway for UAT/production media storage through Railway Storage Buckets.
# - Supabase is kept only as a legacy/fallback mode.
MEDIA_STORAGE_MODE=local
MEDIA_IMAGE_TARGET_BYTES=20480
MEDIA_IMAGE_HARD_LIMIT_BYTES=32768
MEDIA_IMAGE_MAX_DIMENSION_PX=640
MEDIA_IMAGE_MIN_DIMENSION_PX=280
RAILWAY_BUCKET_ENDPOINT_URL=
RAILWAY_BUCKET_NAME=
RAILWAY_BUCKET_ACCESS_KEY_ID=
RAILWAY_BUCKET_SECRET_ACCESS_KEY=
RAILWAY_BUCKET_REGION=us-east-1
SUPABASE_PROJECT_ID=
SUPABASE_SECRET_KEY=
SUPABASE_REWARD_IMAGES_BUCKET=reward-images
SUPABASE_PROMOTION_IMAGES_BUCKET=promotion-assets

SUPABASE_DATABASE_PASSWORD=replace-with-supabase-database-password
SUPABASE_POOLER_HOST=aws-1-ap-southeast-1.pooler.supabase.com
SUPABASE_DATABASE_USER=postgres.replace-with-supabase-project-id
SUPABASE_DATABASE_NAME=postgres
SUPABASE_DATABASE_PORT=5432
SUPABASE_DATABASE_SSLMODE=require
SUPABASE_DATABASE_USE_LIBPQ_COMPAT=true

# SMS/OTP provider is intentionally undecided.
SMS_PROVIDER=mock

# Admin Web
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:3000/api

# End-user mobile / Expo
EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:3000/api
