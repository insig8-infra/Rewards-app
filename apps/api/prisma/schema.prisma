generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  ADMIN
  STAFF
  CONTRACTOR
  TEAM_MEMBER
  SYSTEM
}

enum UserStatus {
  ACTIVE
  DEACTIVATED
}

enum ContractorStatus {
  ACTIVE
  DEACTIVATED
}

enum TeamMemberStatus {
  ACTIVE
  DEACTIVATED
}

enum SiteStatus {
  ACTIVE
  ARCHIVED
}

enum InvoiceStatus {
  IMPORTED
  PARTIALLY_RETURNED
  RETURNED
  CANCELLED
}

enum BusyReturnVoucherStatus {
  IMPORTED
  CONFLICT
}

enum BusyReturnAllocationType {
  NOT_PRINTED_UNAVAILABLE
  PRINTED_CANCEL_ELIGIBLE
  SCANNED_REVIEW_NEEDED
  SCANNED_REVERSED
}

enum ItemCodeStatus {
  IN_USE
  NOT_IN_USE
  NOT_IN_BUSY
}

enum QrStatus {
  NOT_PRINTED
  PRINTED_UNCLAIMED
  RESERVED_IN_CART
  SCANNED_CLAIMED
  EXPIRED
  CANCELLED
  REPRINTED
  REVERSED
}

enum QrTokenStatus {
  ACTIVE
  INVALIDATED
}

enum ScanResult {
  RESERVED
  SUCCESS
  ALREADY_CLAIMED
  EXPIRED
  INVALID
  REPLACED
  CART_CAP_REACHED
  PERMISSION_DENIED
}

enum ScanCartStatus {
  ACTIVE
  COMMITTED
  INVALIDATED
}

enum ScanCartItemStatus {
  RESERVED
  COMMITTED
  REMOVED_BY_USER
  INVALIDATED
}

enum PointsLedgerType {
  SCAN_CREDIT
  QR_REVERSE
  REWARD_REDEEM
  REWARD_CANCEL_RESTORE
  REWARD_FULFILLED
  REWARD_REVOKED_DUE_TO_RETURN
}

enum LedgerSourceType {
  QR_UNIT
  REWARD_CLAIM
  BUSY_RETURN
  ADMIN_ADJUSTMENT
}

enum RewardClaimStatus {
  CHOSEN
  CANCELLED_BY_CONTRACTOR
  REVOKED_DUE_TO_RETURN
  FULFILLED
}

enum RewardCatalogStatus {
  DRAFT
  ACTIVE
  INACTIVE
}

enum AuditSurface {
  END_USER_APP
  ADMIN_MOBILE
  ADMIN_WEB
  BACKEND_JOB
}

enum PromotionStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum PromotionTargetPersona {
  CONTRACTOR
  TEAM_MEMBER
  ALL
}

enum AuthSessionStatus {
  ACTIVE
  REVOKED
}

enum OtpChallengeStatus {
  PENDING
  VERIFIED
  EXPIRED
}

model User {
  id                    String              @id @default(cuid())
  role                  UserRole
  mobileNumber          String              @unique
  displayName           String
  photoUrl              String?
  pinHash               String?
  status                UserStatus          @default(ACTIVE)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  staffProfile          StaffProfile?
  createdStaffProfiles  StaffProfile[]      @relation("StaffCreatedByOwner")
  contractorProfile     Contractor?
  teamMemberProfile     TeamMember?
  scanAttempts          ScanAttempt[]       @relation("ScanActorUser")
  printedQrUnits        QrUnit[]            @relation("QrPrintedBy")
  pointsLedgerEntries   PointsLedgerEntry[] @relation("LedgerCreatedBy")
  fulfilledRewardClaims RewardClaim[]       @relation("RewardFulfilledBy")
  auditEvents           AuditEvent[]        @relation("AuditActor")
  authSessions          AuthSession[]

  @@index([role, status])
}

model StaffProfile {
  id               String    @id @default(cuid())
  userId           String    @unique
  pinHash          String
  createdByOwnerId String?
  lastOpenedAt     DateTime?
  deactivatedAt    DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id])
  createdByOwner   User?     @relation("StaffCreatedByOwner", fields: [createdByOwnerId], references: [id])
}

model Contractor {
  id                     String              @id @default(cuid())
  userId                 String              @unique
  code                   String              @unique
  temporaryMpinHash      String?
  temporaryMpinExpiresAt DateTime?
  mpinHash               String?
  mpinSetAt              DateTime?
  tier                   String?
  totalAccumulatedPoints Int                 @default(0)
  availablePoints        Int                 @default(0)
  belongsToNote          String?
  status                 ContractorStatus    @default(ACTIVE)
  deactivatedAt          DateTime?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  user                   User                @relation(fields: [userId], references: [id])
  sites                  Site[]
  teamMembers            TeamMember[]
  claimedQrUnits         QrUnit[]            @relation("QrClaimedByContractor")
  scanCarts              ScanCart[]
  scanAttempts           ScanAttempt[]
  pointsLedgerEntries    PointsLedgerEntry[]
  rewardClaims           RewardClaim[]
  authSessions           AuthSession[]
  otpChallenges          OtpChallenge[]

  @@index([status])
}

model TeamMember {
  id           String           @id @default(cuid())
  contractorId String
  userId       String?          @unique
  mobileNumber String
  displayName  String?
  status       TeamMemberStatus @default(ACTIVE)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  contractor   Contractor       @relation(fields: [contractorId], references: [id])
  user         User?            @relation(fields: [userId], references: [id])
  scanAttempts ScanAttempt[]

  @@unique([contractorId, mobileNumber])
  @@index([mobileNumber])
}

model AuthSession {
  id                String            @id @default(cuid())
  tokenHash         String            @unique
  actorRole         UserRole
  userId            String?
  contractorId      String?
  teamMemberMobile  String?
  requiresMpinSetup Boolean           @default(false)
  status            AuthSessionStatus @default(ACTIVE)
  expiresAt         DateTime
  lastUsedAt        DateTime?
  revokedAt         DateTime?
  createdAt         DateTime          @default(now())
  user              User?             @relation(fields: [userId], references: [id])
  contractor        Contractor?       @relation(fields: [contractorId], references: [id])

  @@index([tokenHash, status, expiresAt])
  @@index([contractorId, createdAt])
  @@index([userId, createdAt])
}

model OtpChallenge {
  id                     String             @id @default(cuid())
  otpHash                String
  contractorId           String
  contractorMobileNumber String
  teamMemberMobile       String?
  status                 OtpChallengeStatus @default(PENDING)
  expiresAt              DateTime
  verifiedAt             DateTime?
  deviceContext          Json?
  createdAt              DateTime           @default(now())
  contractor             Contractor         @relation(fields: [contractorId], references: [id])

  @@index([contractorId, createdAt])
  @@index([teamMemberMobile, createdAt])
  @@index([status, expiresAt])
}

model Site {
  id                String        @id @default(cuid())
  contractorId      String
  clientName        String
  flatOrApartmentNo String?
  buildingName      String?
  area              String?
  city              String?
  status            SiteStatus    @default(ACTIVE)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  contractor        Contractor    @relation(fields: [contractorId], references: [id])
  qrUnits           QrUnit[]
  scanCarts         ScanCart[]
  scanAttempts      ScanAttempt[]

  @@index([contractorId, status])
}

model BusyInvoice {
  id                String            @id @default(cuid())
  externalInvoiceId String            @unique
  invoiceNumber     String
  invoiceDate       DateTime
  customerRef       String?
  totalAmount       Decimal?          @db.Decimal(12, 2)
  rawSource         Json?
  status            InvoiceStatus     @default(IMPORTED)
  importedAt        DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  lines             BusyInvoiceLine[]
  qrUnits           QrUnit[]
  returnVouchers    BusyReturnVoucher[] @relation("BusyReturnOriginalInvoice")

  @@index([invoiceDate])
  @@index([invoiceNumber])
}

model BusyInvoiceLine {
  id             String      @id @default(cuid())
  invoiceId      String
  externalLineId String
  sku            String
  productName    String
  category       String?
  quantity       Int
  returnedQty    Int         @default(0)
  pointsPerUnit  Int         @default(0)
  rawSource      Json?
  invoice        BusyInvoice @relation(fields: [invoiceId], references: [id])
  qrUnits        QrUnit[]
  returnVoucherLines BusyReturnVoucherLine[] @relation("BusyReturnOriginalLine")
  returnAllocations  BusyReturnAllocation[]  @relation("BusyReturnAllocationInvoiceLine")

  @@unique([invoiceId, externalLineId])
  @@index([sku])
}

model ItemCode {
  id                    String         @id @default(cuid())
  tempItemCode          String         @unique
  itemName              String
  productCategory       String?
  price                 Decimal        @db.Decimal(12, 2)
  fixedPoints           Int?
  percentOfPricePoints  Decimal?       @db.Decimal(7, 3)
  status                ItemCodeStatus @default(IN_USE)
  busyActive            Boolean        @default(true)
  lastBusySyncAt        DateTime?
  missingSince          DateTime?
  sourcePriceField      String         @default("Price")
  rawSource             Json?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  @@index([status])
  @@index([busyActive])
  @@index([itemName])
}

model BusyReturnVoucher {
  id                String                  @id @default(cuid())
  externalReturnId  String                  @unique
  returnNumber      String
  returnDate        DateTime
  originalInvoiceId String
  status            BusyReturnVoucherStatus @default(IMPORTED)
  rawSource         Json?
  importedAt        DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  originalInvoice   BusyInvoice             @relation("BusyReturnOriginalInvoice", fields: [originalInvoiceId], references: [id])
  lines             BusyReturnVoucherLine[]

  @@index([originalInvoiceId, returnDate])
  @@index([returnNumber])
}

model BusyReturnVoucherLine {
  id                    String                  @id @default(cuid())
  returnVoucherId       String
  externalReturnLineId  String
  originalInvoiceLineId String?
  sku                   String
  productName           String
  category              String?
  unit                  String
  quantity              Int
  rawSource             Json?
  returnVoucher         BusyReturnVoucher       @relation(fields: [returnVoucherId], references: [id])
  originalInvoiceLine   BusyInvoiceLine?        @relation("BusyReturnOriginalLine", fields: [originalInvoiceLineId], references: [id])
  allocations           BusyReturnAllocation[]

  @@unique([returnVoucherId, externalReturnLineId])
  @@index([sku])
  @@index([originalInvoiceLineId])
}

model BusyReturnAllocation {
  id                    String                   @id @default(cuid())
  returnLineId          String
  originalInvoiceLineId String?
  qrUnitId              String?                  @unique
  quantity              Int
  type                  BusyReturnAllocationType
  metadata              Json?
  createdAt             DateTime                 @default(now())
  returnLine            BusyReturnVoucherLine    @relation(fields: [returnLineId], references: [id])
  originalInvoiceLine   BusyInvoiceLine?         @relation("BusyReturnAllocationInvoiceLine", fields: [originalInvoiceLineId], references: [id])
  qrUnit                QrUnit?                  @relation(fields: [qrUnitId], references: [id])

  @@index([returnLineId])
  @@index([originalInvoiceLineId])
}

model QrUnit {
  id                     String              @id @default(cuid())
  invoiceId              String
  invoiceLineId          String?
  unitIndex              Int
  productSku             String?
  points                 Int
  status                 QrStatus            @default(NOT_PRINTED)
  expiresAt              DateTime?
  printedAt              DateTime?
  reservedAt             DateTime?
  reservedCartId         String?
  scannedAt              DateTime?
  claimedByContractorId  String?
  siteId                 String?
  printedByUserId        String?
  replacementForQrUnitId String?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  invoice                BusyInvoice         @relation(fields: [invoiceId], references: [id])
  invoiceLine            BusyInvoiceLine?    @relation(fields: [invoiceLineId], references: [id])
  claimedByContractor    Contractor?         @relation("QrClaimedByContractor", fields: [claimedByContractorId], references: [id])
  site                   Site?               @relation(fields: [siteId], references: [id])
  reservedCart           ScanCart?           @relation("QrReservedCart", fields: [reservedCartId], references: [id])
  printedByUser          User?               @relation("QrPrintedBy", fields: [printedByUserId], references: [id])
  replacementForQrUnit   QrUnit?             @relation("QrReplacement", fields: [replacementForQrUnitId], references: [id])
  replacementQrUnits     QrUnit[]            @relation("QrReplacement")
  tokens                 QrToken[]
  scanCartItems          ScanCartItem[]
  scanAttempts           ScanAttempt[]
  pointsLedgerEntries    PointsLedgerEntry[]
  returnAllocations      BusyReturnAllocation[]

  @@unique([invoiceId, unitIndex])
  @@index([status, expiresAt])
  @@index([claimedByContractorId])
}

model QrToken {
  id            String        @id @default(cuid())
  qrUnitId      String
  tokenHash     String        @unique
  status        QrTokenStatus @default(ACTIVE)
  issuedAt      DateTime      @default(now())
  invalidatedAt DateTime?
  qrUnit        QrUnit        @relation(fields: [qrUnitId], references: [id])

  @@index([qrUnitId, status])
}

model ScanCart {
  id                     String              @id @default(cuid())
  contractorId           String
  siteId                 String
  actorRole              UserRole
  actorUserId            String?
  teamMemberSessionId    String?
  teamMemberMobile       String?
  status                 ScanCartStatus      @default(ACTIVE)
  cartTotalPoints        Int                 @default(0)
  scanCapPoints          Int                 @default(1000)
  createdAt              DateTime            @default(now())
  lastActivityAt         DateTime            @default(now())
  committedAt            DateTime?
  contractor             Contractor          @relation(fields: [contractorId], references: [id])
  site                   Site                @relation(fields: [siteId], references: [id])
  reservedQrUnits        QrUnit[]            @relation("QrReservedCart")
  items                  ScanCartItem[]

  @@index([contractorId, siteId, status])
  @@index([teamMemberMobile, lastActivityAt])
}

model ScanCartItem {
  id                 String             @id @default(cuid())
  scanCartId         String
  qrUnitId           String             @unique
  scanAttemptId      String             @unique
  qrValuePoints      Int
  pointsToCredit     Int
  status             ScanCartItemStatus @default(RESERVED)
  reservedAt         DateTime           @default(now())
  committedAt        DateTime?
  removedAt          DateTime?
  invalidatedAt      DateTime?
  invalidationReason String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  scanCart           ScanCart           @relation(fields: [scanCartId], references: [id])
  qrUnit             QrUnit             @relation(fields: [qrUnitId], references: [id])
  scanAttempt        ScanAttempt        @relation(fields: [scanAttemptId], references: [id])

  @@index([scanCartId, status])
}

model ScanAttempt {
  id            String      @id @default(cuid())
  qrUnitId      String?
  tokenHashSeen String
  actorRole     UserRole
  actorUserId   String?
  teamMemberId  String?
  teamMemberMobile    String?
  teamMemberSessionId String?
  deviceContext       Json?
  contractorId  String?
  siteId        String?
  result        ScanResult
  failureReason String?
  qrValuePoints Int?
  creditedPoints Int?
  scanCartItem  ScanCartItem?
  createdAt     DateTime    @default(now())
  qrUnit        QrUnit?     @relation(fields: [qrUnitId], references: [id])
  actorUser     User?       @relation("ScanActorUser", fields: [actorUserId], references: [id])
  teamMember    TeamMember? @relation(fields: [teamMemberId], references: [id])
  contractor    Contractor? @relation(fields: [contractorId], references: [id])
  site          Site?       @relation(fields: [siteId], references: [id])

  @@index([tokenHashSeen])
  @@index([contractorId, createdAt])
  @@index([teamMemberMobile, createdAt])
  @@index([qrUnitId, result])
}

model PointsLedgerEntry {
  id              String           @id @default(cuid())
  contractorId    String
  type            PointsLedgerType
  pointsDelta     Int
  balanceAfter    Int
  sourceType      LedgerSourceType
  sourceId        String
  qrUnitId        String?
  rewardClaimId   String?
  idempotencyKey  String           @unique
  createdByUserId String?
  createdAt       DateTime         @default(now())
  contractor      Contractor       @relation(fields: [contractorId], references: [id])
  qrUnit          QrUnit?          @relation(fields: [qrUnitId], references: [id])
  rewardClaim     RewardClaim?     @relation(fields: [rewardClaimId], references: [id])
  createdByUser   User?            @relation("LedgerCreatedBy", fields: [createdByUserId], references: [id])

  @@index([contractorId, createdAt])
  @@index([sourceType, sourceId])
}

model RewardCatalogItem {
  id             String              @id @default(cuid())
  code           String              @unique
  name           String
  description    String?
  pointsRequired Int
  tierRequired   String?
  imageUrl       String?
  cashValueInr   Int                 @default(0)
  totalQuantity  Int                 @default(0)
  status         RewardCatalogStatus @default(DRAFT)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  images         RewardCatalogImage[]
  rewardClaims   RewardClaim[]

  @@index([status, pointsRequired])
}

model RewardCatalogImage {
  id           String            @id @default(cuid())
  rewardItemId String
  imageUrl     String
  storagePath  String?
  altText      String?
  sortOrder    Int               @default(0)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  rewardItem   RewardCatalogItem @relation(fields: [rewardItemId], references: [id])

  @@index([rewardItemId, sortOrder])
}

model RewardClaim {
  id                  String              @id @default(cuid())
  claimId             String              @unique
  contractorId        String
  rewardItemId        String
  status              RewardClaimStatus   @default(CHOSEN)
  pointsDeducted      Int
  chosenAt            DateTime            @default(now())
  cancelledAt         DateTime?
  fulfilledAt         DateTime?
  fulfilledByOwnerId  String?
  otpVerifiedAt       DateTime?
  contractor          Contractor          @relation(fields: [contractorId], references: [id])
  rewardItem          RewardCatalogItem   @relation(fields: [rewardItemId], references: [id])
  fulfilledByOwner    User?               @relation("RewardFulfilledBy", fields: [fulfilledByOwnerId], references: [id])
  pointsLedgerEntries PointsLedgerEntry[]

  @@index([contractorId, status])
  @@index([rewardItemId])
}

model AuditEvent {
  id          String       @id @default(cuid())
  actorUserId String?
  actorRole   UserRole
  surface     AuditSurface
  action      String
  targetType  String
  targetId    String
  beforeJson  Json?
  afterJson   Json?
  metadata    Json?
  requestId   String?
  createdAt   DateTime     @default(now())
  actorUser   User?        @relation("AuditActor", fields: [actorUserId], references: [id])

  @@index([targetType, targetId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([requestId])
}

model Promotion {
  id            String                 @id @default(cuid())
  title         String
  body          String
  assetUrl      String?
  assetAltText  String?
  overlayText   String?
  backgroundColor String              @default("#00535B")
  overlayTextColor String              @default("#FFFFFF")
  overlayFontSize  Int                 @default(24)
  overlayFontFamily String             @default("noto-sans-devanagari")
  overlayFontStyle String              @default("bold")
  marqueeEnabled  Boolean              @default(false)
  targetPersona PromotionTargetPersona
  status        PromotionStatus        @default(DRAFT)
  startsAt      DateTime?
  endsAt        DateTime?
  archivedAt    DateTime?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  @@index([status, targetPersona, startsAt, endsAt])
}
